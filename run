#!/bin/bash
CWD="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
cd "${CWD}" || exit 1
# shellcheck source=./lib/log.sh
# shellcheck disable=SC1091
source "${CWD}"/lib/log.sh

DOCKER_HUB_USER=slechev
TETRA_DOCKER_HUB_USER=xnetinho
PRODUCT=openwebrxplus
DATE=$(date +%F)
SOURCES_SCRIPTS_FINGERPRINT=$(find "${CWD}/buildfiles/scripts/sources" -maxdepth 1 -type f -name '*.sh' -print0 | sort -z | xargs -0 sha256sum 2>/dev/null | sha256sum | awk '{print $1}')

MAKEFLAGS=-j$(nproc --ignore=4)

# to use APT proxy, run: ./run start-apt-cache
APT_PROXY=
APT_PROXY="http://$(ip -o route get to 8.8.8.8 | sed -n 's/.*src \([0-9.]\+\).*/\1/p'):3142"

HAS_DOCKER=$(docker -v 2>/dev/null || false)
HAS_BUILDX=$(docker buildx version 2>/dev/null || false)

start-apt-cache() {
  log inf "Starting APT-Cache..."
  cd "${CWD}"/apt-cache || exit 1
  docker compose up -d
  cd .. || exit 1
}

stop-apt-cache() {
  log inf "Stopping APT-Cache..."
  cd "${CWD}"/apt-cache || exit 1
  docker compose down -v || true
  cd .. || exit 1
}

check-apt() {
  cd "${CWD}"/apt-cache || exit 1
  local ret
  ret=0
  if [ "$(docker compose ps -q)" != "" ]; then
    log "APT-Cache is running..."
    ret=0
  else
    ret=1
  fi
  cd .. || exit 1
  return $ret
}

clean() {
  local force
  force=${1:-""}

  if [[ "${force}" != "--yes" ]]; then
    log war "This will remove build caches, buildx builders, apt-cache containers, and local cache/work folders."
    read -r -p "Continue? [y/N]: " ans
    if [[ ! "${ans}" =~ ^[Yy]$ ]]; then
      log war "Clean cancelled."
      return 0
    fi
  fi

  log inf "Stopping APT cache stack..."
  stop-apt-cache || true

  log inf "Removing APT cache data..."
  sudo rm -rf "${CWD}/apt-cache/apt-cacher-ng" || true
  docker image rm sameersbn/apt-cacher-ng >/dev/null 2>&1 || true

  log inf "Removing builder containers..."
  docker ps -aq --filter name=buildx_buildkit_owrxp-builder | xargs -r docker rm -f >/dev/null 2>&1 || true

  log inf "Removing buildx builders..."
  docker buildx rm owrxp-builder >/dev/null 2>&1 || true
  docker buildx ls 2>/dev/null | awk '/owrxp-builder/{print $1}' | xargs -r -n1 docker buildx rm >/dev/null 2>&1 || true

  log inf "Pruning builder cache..."
  docker builder prune -af >/dev/null 2>&1 || true

  log inf "Removing buildx volumes..."
  docker volume ls -q | grep -E '^buildx_buildkit_owrxp-builder' | xargs -r docker volume rm >/dev/null 2>&1 || true

  log inf "Removing local cache/work folders..."
  sudo rm -rf "${CWD}/cache" "${CWD}/work" || true

  log inf "Pruning stopped containers and dangling networks..."
  docker container prune -f >/dev/null 2>&1 || true
  docker network prune -f >/dev/null 2>&1 || true

  log suc "Clean completed. Fresh build state is ready."
}

check-docker() {
  log inf "Docker: [4[${HAS_DOCKER}]], [6[${HAS_BUILDX}]]"
  if [ -z "${HAS_DOCKER}" ] || [ -z "${HAS_BUILDX}" ]; then
    log err "Cannot find Docker or BuildX. Please install them."
    exit 1
  fi
}

add-admin() {
  docker exec -it ${PRODUCT} /usr/bin/openwebrx admin adduser admin
}

get_owrxp_version() {
  curl https://raw.githubusercontent.com/luarvique/openwebrx/master/owrx/version.py 2>/dev/null |
    grep -v "looseversion" |
    grep "_versionstring" |
    cut -d '"' -f 2
}

get_owrxp_commit() {
  git ls-remote https://github.com/luarvique/openwebrx.git refs/heads/master 2>/dev/null | awk 'NR==1 {print $1}'
}

# ── Lightweight build (softmbe / tetra) ──────────────────────────────────────
# Builds images that extend a pre-existing Docker Hub base without the heavy
# multi-stage compilation pipeline. No APT cache server required.
#
# Arguments:
#   $1  DOCKERFILE   path to the Dockerfile
#   $2  PROD_NAME    image name (without user prefix)
#   $3  HUB_USER     Docker Hub user (default: DOCKER_HUB_USER)
#   $4  CUSTOM_TAG   optional custom tag; if set, only this tag is created
#                    (no 'latest', no version tag)

build-light() {
  local DOCKERFILE="${1}"
  local PROD_NAME="${2}"
  local HUB_USER="${3:-${DOCKER_HUB_USER}}"
  local CUSTOM_TAG="${4:-}"

  if [ ! -f "${DOCKERFILE}" ]; then
    log err "Cannot find Dockerfile '${DOCKERFILE}'"
    exit 1
  fi

  local CACHE_DIR
  CACHE_DIR="$(pwd)/cache/${PROD_NAME//[^a-zA-Z0-9._-]/_}"
  mkdir -p "${CACHE_DIR}"

  local VER
  VER=$(get_owrxp_version)

  # Build tag list: custom tag OR (version + latest)
  local tag_args=()
  if [ -n "${CUSTOM_TAG}" ]; then
    log inf "Building '${HUB_USER}/${PROD_NAME}:${CUSTOM_TAG}' (custom tag) from ${DOCKERFILE}"
    tag_args=(-t "${HUB_USER}/${PROD_NAME}:${CUSTOM_TAG}")
  else
    log inf "Building '${HUB_USER}/${PROD_NAME}:${VER}' + ':latest' from ${DOCKERFILE}"
    tag_args=(-t "${HUB_USER}/${PROD_NAME}:${VER}" -t "${HUB_USER}/${PROD_NAME}:latest")
  fi

  log inf "Using cache dir: ${CACHE_DIR}"
  echo

  docker buildx create \
    --name owrxp-builder \
    --driver docker-container \
    --bootstrap \
    --use \
    --driver-opt network=host \
    2>/dev/null || true

  local cache_from_arg=()
  [ -f "${CACHE_DIR}/index.json" ] && cache_from_arg=(--cache-from "type=local,src=${CACHE_DIR}")

  time docker buildx build -f "${DOCKERFILE}" \
    --platform linux/amd64,linux/arm64,linux/arm/v7 \
    "${cache_from_arg[@]}" \
    --cache-to type=local,dest="${CACHE_DIR}" \
    --build-arg MAKEFLAGS="${MAKEFLAGS}" \
    --build-arg APT_PROXY="${APT_PROXY}" \
    "${tag_args[@]}" \
    --pull \
    --push \
    ./buildfiles || exit 1
}

# ── build-softmbe ─────────────────────────────────────────────────────────────
# Builds the softmbe image directly from slechev/openwebrxplus on Docker Hub.
# Does NOT require the heavy main-image compilation.
# Chains into build-tetra automatically when done.
#
# Options:
#   --tag TAG   use a custom tag instead of 'latest' + version

build-softmbe() {
  local CUSTOM_TAG=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tag) CUSTOM_TAG="${2:?'--tag requires a value'}"; shift ;;
      *) log war "Unknown option for build-softmbe: $1" ;;
    esac
    shift
  done

  log inf "Building SoftMBE image directly from Docker Hub base..."
  build-light "buildfiles/Dockerfile-softmbe" "${PRODUCT}-softmbe" "${DOCKER_HUB_USER}" "${CUSTOM_TAG}"

  log inf "SoftMBE build complete. Starting TETRA build..."
  build-tetra ${CUSTOM_TAG:+--tag "${CUSTOM_TAG}"}
}

# ── build-tetra ───────────────────────────────────────────────────────────────
# Builds the tetra image (xnetinho/openwebrxplus-tetra) from the softmbe base.
# Does NOT require the heavy main-image compilation.
# This is always the last step in the build chain — cleans up the builder.
#
# Options:
#   --tag TAG   use a custom tag instead of 'latest' + version
#               Example: ./run build-tetra --tag develop-tetra-frequency

build-tetra() {
  local CUSTOM_TAG=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tag) CUSTOM_TAG="${2:?'--tag requires a value'}"; shift ;;
      *) log war "Unknown option for build-tetra: $1" ;;
    esac
    shift
  done

  log inf "Building TETRA image directly from SoftMBE base..."
  build-light "buildfiles/Dockerfile-tetra" "${PRODUCT}-tetra" "${TETRA_DOCKER_HUB_USER}" "${CUSTOM_TAG}"

  log inf "Removing docker builder (keeping state/caches for next use)..."
  docker buildx rm --keep-state owrxp-builder 2>/dev/null || true

  if [ -n "${CUSTOM_TAG}" ]; then
    log suc "Build complete: ${TETRA_DOCKER_HUB_USER}/${PRODUCT}-tetra:${CUSTOM_TAG}"
  else
    log suc "Full build chain complete: ${DOCKER_HUB_USER}/${PRODUCT} → ${DOCKER_HUB_USER}/${PRODUCT}-softmbe → ${TETRA_DOCKER_HUB_USER}/${PRODUCT}-tetra"
  fi
}

# ── build (main — heavy) ─────────────────────────────────────────────────────
#
# Options:
#   --force-final   bypass final layer cache
#   --tag TAG       use a custom tag instead of 'latest' + version

build() {
  check-apt || start-apt-cache

  local force_final
  force_final=0
  local CUSTOM_TAG=""
  local build_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force-final)
        force_final=1
        ;;
      --tag)
        CUSTOM_TAG="${2:?'--tag requires a value'}"
        shift
        ;;
      *)
        build_args+=("$1")
        ;;
    esac
    shift
  done

  if [ "${#build_args[@]}" -gt 2 ]; then
    log err "Too many arguments for build command."
    usage
    exit 1
  fi

  local DOCKERFILE
  DOCKERFILE=${build_args[0]:-"buildfiles/Dockerfile"}

  if [ ! -f "${DOCKERFILE}" ]; then
    log err "Cannot find Dockerfile '${DOCKERFILE}'"
    exit 1
  fi

  local PROD
  PROD=${build_args[1]:-"$PRODUCT"}

  local PRODUCT_EXTRA
  PRODUCT_EXTRA=""
  if [[ "${DOCKERFILE}" == *Dockerfile* ]]; then
    PRODUCT_EXTRA="${DOCKERFILE#*Dockerfile}"
  fi

  local CACHE_DIR
  CACHE_DIR="${PROD}${PRODUCT_EXTRA}"
  CACHE_DIR=${CACHE_DIR//[^a-zA-Z0-9._-]/_}

  CACHE_DIR="$(pwd)/cache/${CACHE_DIR}"
  log inf "Using cache dir: ${CACHE_DIR}"

  local VER
  VER=$(get_owrxp_version)
  local OWRX_REPO_COMMIT
  OWRX_REPO_COMMIT=$(get_owrxp_commit)
  if [[ -z "${OWRX_REPO_COMMIT}" ]]; then
    log war "Cannot resolve OpenWebRX upstream commit, using fallback key from version ${VER}."
    OWRX_REPO_COMMIT="version-${VER}"
  fi
  local FINAL_CACHE_BUSTER
  FINAL_CACHE_BUSTER="${OWRX_REPO_COMMIT}"
  if [ "$force_final" -eq 1 ]; then
    FINAL_CACHE_BUSTER="force-$(date +%s)"
    log war "--force-final enabled: bypassing final layer cache (${FINAL_CACHE_BUSTER})."
  fi

  # Build tag list: custom tag OR (version + latest)
  local tag_args=()
  if [ -n "${CUSTOM_TAG}" ]; then
    log inf "Building '${PROD}${PRODUCT_EXTRA}:${CUSTOM_TAG}' (custom tag)"
    tag_args=(-t "${DOCKER_HUB_USER}/${PROD}${PRODUCT_EXTRA}:${CUSTOM_TAG}")
  else
    log inf "Building '${PROD}${PRODUCT_EXTRA}:${VER}' + ':latest'"
    tag_args=(-t "${DOCKER_HUB_USER}/${PROD}${PRODUCT_EXTRA}:${VER}" -t "${DOCKER_HUB_USER}/${PROD}${PRODUCT_EXTRA}")
  fi

  log inf "OpenWebRX upstream commit key: ${OWRX_REPO_COMMIT}"
  echo

  mkdir -p "${CACHE_DIR}"
  log inf "Creating docker builder for multiarch..."
  docker buildx create \
    --name owrxp-builder \
    --driver docker-container \
    --bootstrap \
    --use \
    --driver-opt network=host \
    2>/dev/null || true

  log inf "Building $PROD$PRODUCT_EXTRA from $DOCKERFILE for AMD64, ARM64 and ARM32v7."
  log inf "Sources fingerprint: ${SOURCES_SCRIPTS_FINGERPRINT}"
  time docker buildx build -f "${DOCKERFILE}" \
    --platform linux/amd64,linux/arm64,linux/arm/v7 \
    --build-context mycache="${CACHE_DIR}" \
    --cache-from type=local,src="${CACHE_DIR}" \
    --cache-to type=local,dest="${CACHE_DIR}" \
    --build-arg MAKEFLAGS="${MAKEFLAGS}" \
    --build-arg BUILD_DATE="${DATE}" \
    --build-arg SOURCES_SCRIPTS_FINGERPRINT="${SOURCES_SCRIPTS_FINGERPRINT}" \
    --build-arg OWRX_REPO_COMMIT="${OWRX_REPO_COMMIT}" \
    --build-arg FINAL_CACHE_BUSTER="${FINAL_CACHE_BUSTER}" \
    --build-arg PRODUCT="${PROD}${PRODUCT_EXTRA}" \
    --build-arg OWRXVERSION="${VER}" \
    --build-arg APT_PROXY="${APT_PROXY}" \
    "${tag_args[@]}" \
    --pull \
    --push \
    ./buildfiles || exit 1

  # Chain into lightweight softmbe → tetra builds
  if [[ "${PRODUCT_EXTRA}" != *softmbe* ]] && [[ "${PRODUCT_EXTRA}" != *tetra* ]]; then
    log inf "Main build complete. Starting SoftMBE + TETRA builds..."
    build-softmbe ${CUSTOM_TAG:+--tag "${CUSTOM_TAG}"}
  fi
}

# ── Container run helpers ─────────────────────────────────────────────────────

run_internal() {
  mkdir -p work/owrx/var work/owrx/etc
  docker run --rm \
    -h ${PRODUCT} \
    --name ${PRODUCT} \
    --device /dev/bus/usb \
    -p 8073:8073 \
    -v ./work/owrx/var:/var/lib/openwebrx \
    -v ./work/owrx/etc:/etc/openwebrx \
    -e FORWARD_LOCALPORT_1234=5678 \
    -e TZ=Europe/Sofia \
    "${1}"
}

run() {
  local IMAGE
  IMAGE=${1:-"${DOCKER_HUB_USER}/${PRODUCT}"}
  docker pull ${IMAGE} || true
  run_internal ${IMAGE}
}

run-softmbe() {
  local IMAGE="${DOCKER_HUB_USER}/${PRODUCT}-softmbe"
  docker pull "${IMAGE}" || true
  run_internal "${IMAGE}"
}

run-tetra() {
  local IMAGE="${TETRA_DOCKER_HUB_USER}/${PRODUCT}-tetra"
  docker pull "${IMAGE}" || true
  run_internal "${IMAGE}"
}

dev_internal() {
  check-apt || start-apt-cache
  mkdir -p work/owrx/var work/owrx/etc
  docker run -it --rm \
	--privileged \
	--net=host \
	-v /sys:/sys \
	-v /dev:/dev \
    -p 8073:8073 \
    --device /dev/bus/usb \
    -v ./work/owrx/var:/var/lib/openwebrx \
    -v ./work/owrx/etc:/etc/openwebrx \
	-v ./work/openwebrx:/openwebrx \
    --name ${PRODUCT}-dev \
    --entrypoint /init \
    -v "$(pwd)"/cache:/build_cache \
    -e http_proxy="${APT_PROXY}" \
    -e FORWARD_LOCALPORT_1234=5678 \
    -e TZ=Europe/Sofia \
    "${1}" /bin/bash
}

dev() {
  local IMAGE
  IMAGE=${1:-"${DOCKER_HUB_USER}/${PRODUCT}"}
  docker pull ${IMAGE} || true
  dev_internal ${IMAGE}
}

dev-tetra() {
  local IMAGE="${TETRA_DOCKER_HUB_USER}/${PRODUCT}-tetra"
  docker pull "${IMAGE}" || true
  dev_internal "${IMAGE}"
}

## MAIN
log "Builder for OpenWebRX+ Docker Image"
check-docker

usage() {
  log war "Usage: $0 [command] [options]"
  log war ". commands:"
  log war "... build [--force-final] [--tag TAG] [Dockerfile]  - full build (heavy); chains softmbe→tetra automatically"
  log war "... build-softmbe [--tag TAG]                        - build softmbe image from Docker Hub base; chains tetra"
  log war "... build-tetra   [--tag TAG]                        - build tetra image (${TETRA_DOCKER_HUB_USER}/${PRODUCT}-tetra) from softmbe base"
  log war "... run [image]                                       - run container from latest image"
  log war "... run-softmbe                                       - run softmbe container"
  log war "... run-tetra                                         - run tetra container"
  log war "... dev [image]                                       - start container with bash shell"
  log war "... dev-tetra                                         - start tetra container with bash shell"
  log war "... add-admin                                         - add 'admin' user to the running container"
  log war "... clean [--yes]                                     - remove builders, caches, apt-cache stack, and local work/cache"
  echo
  log war "Build chain: build → build-softmbe → build-tetra"
  log war "You can start at any point in the chain."
  echo
  log war "The --tag option creates a single custom tag instead of 'latest' + version:"
  log war "[6[  ./run build-tetra --tag develop-tetra-frequency]]"
  log war "[6[  ./run build-tetra --tag meu-teste-2]]"
  log war "[6[  ./run build-softmbe --tag homolog]]   # aplica também ao build-tetra encadeado"
  echo
  log war "You can specify MAKEFLAGS for docker builds:"
  log war "[6[MAKEFLAGS=\"-j4\" $0]]"
}

if [[ $(type -t "$1") == 'function' ]]; then
  # shellcheck disable=SC2068
  "$@"
else
  [ "$1" != "" ] && log err "Command '$1' not found..." && echo
  usage
fi
